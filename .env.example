TELEGRAM_BOT_TOKEN=123456:telegram-token
DRIFT_API_TOKEN=dft_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram user IDs allowed to write to the bot.
ALLOWED_USER_IDS=123456789,987654321

# Group/supergroup chat IDs where the bot responds only when mentioned by @username.
ALLOWED_GROUP_CHAT_IDS=-1001234567890

# Optional defaults.
DRIFT_BASE_URL=https://drift.neuraldeep.ru/v1
DRIFT_MODEL=gpt-oss-120b
SQLITE_PATH=/data/bot.sqlite3
REQUEST_TIMEOUT_SECONDS=180
